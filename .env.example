# Anthropic Claude API key — required
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# JWT signing secret — change to a long random string in production
SECRET_KEY=change-me-to-a-long-random-string

# PostgreSQL connection (used by the backend service)
DATABASE_URL=postgresql+asyncpg://postgres:password@db:5432/communityai

# PostgreSQL password (used by docker-compose.prod.yml for the db service)
POSTGRES_PASSWORD=change-me-in-production

# Admin registration secret
ADMIN_SECRET=change-this-admin-secret

# Community matching tuning
SIMILARITY_THRESHOLD=0.65
MIN_MESSAGES_FOR_PROFILE=6
RECLUSTER_EVERY_N_USERS=10

# Optional: Brave Search API key (for event/web search tools)
BRAVE_API_KEY=

# Optional: Eventbrite API key (for event announcements)
EVENTBRITE_API_KEY=
